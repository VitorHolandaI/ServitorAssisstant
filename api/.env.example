# Template — copy to api/.env and fill in your values.

# IP of this machine (used to build MCP address; in Docker, set to "mcp")
SERVER_IP=localhost

# Ollama base URL (in Docker, set to "http://ollama:11434")
OLLAMA_HOST=http://127.0.0.1:11434

# IP of the Raspberry Pi client that plays audio
CLIENT_IP=192.168.0.22

# Absolute path to the Piper TTS voice model (.onnx)
VOICE_PATH=/home/vitor/git/ServitorAssisstant/voice_models/en_US-ryan-medium.onnx

# Wake-on-LAN — MAC address of the machine to wake
WAKE_MAC=YOUR_MAC_HERE

# Network interface to send the magic packet through (Proxmox bridge, etc.)
WAKE_INTERFACE=vmbr0
