# Copy this file to .env and replace YOUR_SERVER_IP with your machine's IP.
# Use your VPN/LAN IP so the frontend is reachable from other devices, or localhost for local-only.
VITE_REACT_APP_API_URL=http://YOUR_SERVER_IP:8000/receive_message
VITE_REACT_APP_API_URL_STREAM=http://YOUR_SERVER_IP:8000/stream_message
VITE_REACT_APP_API_URL_AUDIO=http://YOUR_SERVER_IP:8000
