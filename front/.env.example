# Copy to front/.env and set your server IP.
# Use LAN/VPN IP for multi-device access, or localhost for local-only.
VITE_SERVER_IP=localhost

# Override the full API base URL (takes priority over VITE_SERVER_IP).
# For Docker: set VITE_API_BASE=/api (handled automatically via Dockerfile.frontend build arg).
# For local dev: leave unset.
# VITE_API_BASE=/api
